---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { getPostImageUrl } from "@/utils/getPostImageUrl";
import { toTransitionName } from "@/utils/toTransitionName";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
const postUrl = getPostUrl(id, filePath, Astro.currentLocale);
const imageUrl = getPostImageUrl({ id, filePath, data }, Astro.currentLocale);
---

<li class="my-6">
  <a
    href={postUrl}
    class:list={[
      "group block",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <img
      src={imageUrl}
      alt=""
      width={1200}
      height={315}
      loading="lazy"
      decoding="async"
      class="border-border mb-3 aspect-[1200/315] w-full rounded-lg border object-cover"
    />
    <Heading
      transition:name={toTransitionName(title)}
      class:list={[
        "text-accent text-lg font-medium",
        "decoration-dashed underline-offset-4 group-hover:underline",
      ]}
    >
      {title}
    </Heading>
  </a>
  <Datetime {...props} />
  <p>{description}</p>
</li>
